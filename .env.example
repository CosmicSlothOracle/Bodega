# ─── Public site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bodega-buehlot.de

# ─── Reservations: DISH (existing contract, "Reserve with Google" included) ─
# Public restaurant ID used in the deep-link https://reserve.dish.co/{id}
NEXT_PUBLIC_DISH_RESTAURANT_ID=343512

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── PostHog ────────────────────────────────────────────────────────────────
# Browser SDK key (Project API Key, starts with `phc_…`)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Server-side query API (Personal API Key, starts with `phx_…`) — only set
# when you want the dashboard /dashboard/analytics to read live KPIs.
POSTHOG_API_HOST=https://eu.posthog.com
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# ─── Email (Resend) — used for event confirmations + owner reports ──────────
RESEND_API_KEY=
RESEND_FROM=Bodega Bühlot <hola@bodega-buehlot.de>

# ─── SMS (Twilio) — optional, used for event reminders / no-show prevention ─
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Telegram Bot — staff notifications (shifts, swap requests) ─────────────
# Token from @BotFather. Username (without @) is also exposed publicly so the
# onboarding link `https://t.me/<username>?start=<code>` can be rendered.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Random secret used to authenticate inbound webhook calls from Telegram.
# Configure on `setWebhook` and verify in /api/telegram/webhook.
TELEGRAM_WEBHOOK_SECRET=

# ─── Payload (only when /admin is mounted) ──────────────────────────────────
DATABASE_URL=
PAYLOAD_SECRET=
